    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.18.0",
    "next": "^14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.8.1",
