# Supabase Connection Pooling (Transaction Mode - Port 6543)
# Used by the application at runtime for all queries
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[aws-0-region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase Direct Connection (Session Mode - Port 5432)
# Used only for Prisma migrations and schema pushes (npx prisma db push / migrate)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[aws-0-region].pooler.supabase.com:5432/postgres"
